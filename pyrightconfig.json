{
  "venvPath": ".",
  "venv": ".venv",
  "include": [
    "pycaprio",
    "tests"
  ],
  "exclude": [
    "pycaprio.egg-info",
    "build",
    "dist",
    ".venv",
    "**/node_modules",
    "**/__pycache__",
    "**/.*"
  ],
  "typeCheckingMode": "basic",
  "reportMissingTypeStubs": false,
  "reportOptionalMemberAccess": false,
  "reportMissingImports": false
}
